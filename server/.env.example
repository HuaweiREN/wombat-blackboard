# DeepSeek / Anthropic-compatible LLM
DEEPSEEK_API_KEY=sk-your-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_MODEL=deepseek-v4-pro
PORT=3001
# 可选：仅用于飞书卡片里的“打开预览链接”。WebSocket 长连接接收事件不需要公网回调地址。
# 如果只需要机器人回复 Mermaid 代码，可保持 localhost 或不配置，服务会自动回退到本机地址。
PUBLIC_BASE_URL=http://localhost:3001

# Feishu / Lark bot WebSocket event subscription
# 为避免密钥进入版本库，请将实际 app_secret 写入 server/.env（该文件已被 .gitignore 忽略）。
FEISHU_WS_ENABLED=false
FEISHU_APP_ID=cli_a939ec1049f8dbcc
FEISHU_APP_SECRET=replace-with-your-app-secret
FEISHU_DOMAIN=https://open.feishu.cn
FEISHU_MAX_REPLY_RETRIES=2

# Local integration test switches. Never enable both in production.
WOMBAT_MOCK_LLM=false
FEISHU_MOCK_SEND=false
